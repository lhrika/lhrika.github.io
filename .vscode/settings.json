{
	"editor.formatOnSave": true,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.tabSize": 2,
	"[markdown]": {
		"editor.wordWrap": "on"
	},
	"eslint.useFlatConfig": true,
	"files.associations": {
		"*.css": "tailwindcss"
	},
	"deno.enablePaths": ["supabase/functions"],
	"deno.lint": true,
	"deno.unstable": [
		"bare-node-builtins",
		"byonm",
		"sloppy-imports",
		"unsafe-proto",
		"webgpu",
		"broadcast-channel",
		"worker-options",
		"cron",
		"kv",
		"ffi",
		"fs",
		"http",
		"net"
	]
}
